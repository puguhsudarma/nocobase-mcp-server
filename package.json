{
  "name": "@reroet/nocobase-mcp-server",
  "version": "1.0.4",
  "description": "MCP server for NocoBase — manage collections, UI schemas, flowPage blocks, and JS blocks via AI assistants like Claude",
  "type": "module",
  "bin": {
    "nocobase-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "start": "tsx src/index.ts",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nocobase",
    "ai",
    "claude",
    "no-code",
    "low-code",
    "automation"
  ],
  "author": "Reroet <wayanpuguhsudarma@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puguhsudarma/nocobase-mcp-server.git"
  },
  "homepage": "https://github.com/puguhsudarma/nocobase-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/puguhsudarma/nocobase-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openapi2mcptools": "^0.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
